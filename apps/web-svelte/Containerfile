# Build stage
FROM node:24-alpine AS builder

# Enable corepack for pnpm
RUN corepack enable && corepack prepare pnpm@10.20.0 --activate

# Set CI environment variable for pnpm
ENV CI=true

WORKDIR /app

# Copy workspace configuration and lockfile (leveraging Docker cache layers)
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.eslint.json .npmrc ./

# Copy only the necessary source files for building
COPY packages packages
COPY apps/web-svelte apps/web-svelte
COPY nx.json graphql.config.yml ./

# Install dependencies with frozen lockfile
RUN pnpm install --frozen-lockfile --prefer-offline

# Build the application
RUN pnpm --filter web-svelte... build

# Production stage
FROM node:24-alpine

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001

WORKDIR /app

# Copy built application and dependencies from builder stage
COPY --chown=nodejs:nodejs --from=builder /app/apps/web-svelte/build apps/web-svelte/build
COPY --chown=nodejs:nodejs --from=builder /app/node_modules node_modules
COPY --chown=nodejs:nodejs --from=builder /app/apps/web-svelte/node_modules apps/web-svelte/node_modules

# Copy package.json for reference
COPY --chown=nodejs:nodejs apps/web-svelte/package.json apps/web-svelte/

# Switch to non-root user
USER nodejs

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000', (r)=>{if(r.statusCode!==200)throw new Error(r.statusCode)})"

WORKDIR /app/apps/web-svelte

# Expose port
EXPOSE 3000

# Set environment variables
ENV NODE_ENV=production
ENV PORT=3000

# Start the application
CMD ["node", "build"]
