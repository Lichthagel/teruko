# Build stage
FROM node:24-alpine AS builder

# Enable corepack for pnpm
RUN corepack enable && corepack prepare pnpm@10.20.0 --activate

# Set CI environment variable for pnpm
ENV CI=true

WORKDIR /app

# Copy workspace configuration and lockfile (leveraging Docker cache layers)
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.eslint.json .env.schema ./

# Copy only the necessary source files for building
COPY packages packages
COPY apps/web-svelte apps/web-svelte
COPY nx.json graphql.config.yml ./

# Install dependencies with frozen lockfile
RUN pnpm install --frozen-lockfile --prefer-offline

# Build the application
RUN pnpm --filter web-svelte... build

# Production stage
FROM node:24-alpine

WORKDIR /app

# Copy the entire project from builder
COPY --from=builder /app ./

# Expose port
EXPOSE 3000

# Set environment variables
ENV NODE_ENV=production
ENV PORT=3000

# Set working directory to the svelte app
WORKDIR /app/apps/web-svelte

# Start the application
CMD ["node", "build"]
